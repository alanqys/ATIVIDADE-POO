class Conta {
    private double saldo;

    public double getSaldo() {
        return this.saldo;
    }

    public void deposita(double valor) {
        if (valor > 0) {
            this.saldo += valor;
        }
    }

    public void atualiza(double taxaSelic) {
        this.saldo = this.saldo * (1 + taxaSelic);
    }
}

class ContaCorrente extends Conta {
    @Override
    public void atualiza(double taxaSelic) {
        super.atualiza(taxaSelic * 2);
        this.deposita(-15); 
    }
}

class ContaPoupanca extends Conta {
    @Override
    public void atualiza(double taxaSelic) {
        super.atualiza(taxaSelic * 0.75);
    }
}

class Banco {
    private Conta[] contas = new Conta[10];
    private int proximaPosicaoLivre = 0;

    public void adiciona(Conta c) {
        if (this.proximaPosicaoLivre < this.contas.length) {
            this.contas[this.proximaPosicaoLivre] = c;
            this.proximaPosicaoLivre++;
        }
    }

    public Conta pega(int x) {
        return this.contas[x];
    }

    public int pegaTotalDeContas() {
        return this.proximaPosicaoLivre;
    }
}

class AtualizadorDeContas {
    private double saldoTotal = 0;
    private double selic;

    AtualizadorDeContas(double selic) {
        this.selic = selic;
    }

    public void roda(Conta c) {
        System.out.println("Saldo anterior: " + c.getSaldo());
        c.atualiza(this.selic);
        System.out.println("Saldo novo: " + c.getSaldo());
        this.saldoTotal += c.getSaldo();
    }

    public double getSaldoTotal() {
        return this.saldoTotal;
    }
}

public class Main {
    public static void main(String[] args) {
        Banco meuBanco = new Banco();
        
        Conta c = new Conta();
        c.deposita(1000);
        
        ContaCorrente cc = new ContaCorrente();
        cc.deposita(1000);
        
        ContaPoupanca cp = new ContaPoupanca();
        cp.deposita(1000);

        meuBanco.adiciona(c);
        meuBanco.adiciona(cc);
        meuBanco.adiciona(cp);

        AtualizadorDeContas adc = new AtualizadorDeContas(0.01);

        for (int i = 0; i < meuBanco.pegaTotalDeContas(); i++) {
            adc.roda(meuBanco.pega(i));
            System.out.println("----------");
        }

        System.out.println("Total do Banco: " + adc.getSaldoTotal());
    }
}
